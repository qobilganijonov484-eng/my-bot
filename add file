    await call.message.answer(
        f"""🧾 BUYURTMA

📦 {name}
💰 {price}

💳 Karta:
{CARD_NUMBER}
👤 {CARD_OWNER}

📌 Endi o‘yin ID ni yozing (raqam)."""
    )

    await bot.send_message(
        ADMIN_ID,
        f"""🆕 YANGI BUYURTMA

📦 {name}
💰 {price}

👤 USER ID: {call.from_user.id}
👤 USERNAME: @{call.from_user.username or "yo'q"}"""
    )

    await call.answer()

