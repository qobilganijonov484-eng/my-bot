# =========================
# 📌 MENU
# =========================

def menu():
    kb = InlineKeyboardBuilder()
    for key, value in PRODUCTS.items():
        kb.button(text=value[0], callback_data=key)
    kb.adjust(1)
    return kb.as_markup()

# =========================
# 📌 START
# =========================

@dp.message(F.text == "/start")
async def start(message: Message):
    await message.answer(
        "💎 DONAT SHOP\nMahsulotni tanlang:",
        reply_markup=menu()
    )

